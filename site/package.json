{
  "name": "site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:new-ui": "vite --config src/new-ui/vite.config.ts",
    "dev:new-ui:production": "vite --config src/new-ui/vite.production.config.ts",
    "build": "tsc -b && tsc -p src/new-ui/tsconfig.json --noEmit && vite build && node scripts/check-no-mojibake.mjs --include-dist && node scripts/check-copy-quality.mjs --include-dist && node scripts/check-new-ui-production-runtime.mjs",
    "build:new-ui": "tsc -p src/new-ui/tsconfig.json --noEmit && vite build --config src/new-ui/vite.config.ts",
    "build:new-ui:production": "tsc -p src/new-ui/tsconfig.json --noEmit && vite build --config src/new-ui/vite.production.config.ts && node scripts/check-new-ui-production-runtime.mjs --include-new-ui-dist-production",
    "lint:new-ui": "eslint src/new-ui --ignore-pattern dist --ignore-pattern dist-production",
    "test:new-ui:production": "node scripts/check-new-ui-production-runtime.mjs",
    "test:new-ui:round3b": "node scripts/check-new-ui-production-runtime.mjs && node scripts/check-round3b-production-integration.mjs",
    "test:phase-b": "node scripts/check-phase-b-production-rollout.mjs",
    "test:phase-b1": "node scripts/check-no-mojibake.mjs && node scripts/check-copy-quality.mjs && node scripts/check-phase-b1-baseline.mjs",
    "test:phase-c": "node scripts/check-phase-c-account-linking.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:new-ui": "vite preview --config src/new-ui/vite.config.ts",
    "preview:new-ui:production": "vite preview --config src/new-ui/vite.production.config.ts"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/tajawal": "^5.2.7",
    "firebase": "^12.13.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
